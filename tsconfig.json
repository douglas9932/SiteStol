{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
